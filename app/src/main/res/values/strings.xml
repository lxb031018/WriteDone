    <string name="legal_pp_change_tech">技术升级</string>
    <string name="legal_pp_change_feedback">用户反馈建议</string>
    <string name="legal_pp_section8_2">8.2 变更方式</string>
    <string name="legal_pp_change_methods_intro">任何变更将通过以下方式公布:</string>
